{
  // ─── Python settings ─────────────────────────────────────────────────────────
  "python.analysis.autoSearchPaths": true,
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingImports": "none"
  },
  "python.analysis.extraPaths": ["${workspaceFolder}/src"],
  "python.envFile": "${workspaceFolder}/.env",
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // ─── Test settings ────────────────────────────────────────────────────────────
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["tests"],
  "python.testing.cwd": "${workspaceFolder}",
  "python.testing.pytestPath": "${workspaceFolder}/.venv/bin/pytest",
  "python.testing.autoTestDiscoverOnSaveEnabled": true,

  // ─── ty: choose ONE option ────────────────────────────────────────────────────
  //
  // OPTION A — ty as full language server (replaces Pylance for hover, completions, go-to-def)
  //   Install extension: https://marketplace.visualstudio.com/items?itemName=astral-sh.ty
  //   Uncomment ALL lines below:

  // Disable Python extension's language server - ty provides LSP + diagnostics
  "python.languageServer": "None",

  // ty diagnostics for the whole workspace (not only open files)
  "ty.diagnosticMode": "workspace",

  // Use ty from the configured interpreter environment
  "ty.importStrategy": "fromEnvironment",

  // Point to the project's virtual environment interpreter
  "ty.interpreter": ["${workspaceFolder}/.venv/bin/python"],

  // Enable auto-import suggestions in completions
  "ty.completions.autoImport": true,

  // Inlay hints configuration (optional - adjust as preferred)
  "ty.inlayHints.variableTypes": true,
  "ty.inlayHints.callArgumentNames": true,
  "chat.tools.terminal.autoApprove": {
    "uv": true
  }

  //
  // OPTION B — ty diagnostics only, keep Pylance for completions/hover
  //   Install extension: https://marketplace.visualstudio.com/items?itemName=astral-sh.ty
  //   Comment ALL "OPTION A" lines above. Uncomment ALL lines below:
  //
  //   "python.languageServer": "Pylance",
  //   "ty.importStrategy": "fromEnvironment",
  //   "ty.interpreter": ["${workspaceFolder}/.venv/bin/python"],
  //   "ty.diagnosticMode": "workspace",
  //   "ty.disableLanguageServices": true,
  //
  // ─────────────────────────────────────────────────────────────────────────────
}

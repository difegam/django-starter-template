{
  "name": "django-tailwindcss-starter",
  "version": "1.0.0",
  "description": "A starter template for integrating Tailwind CSS with Django projects.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "npx @tailwindcss/cli -i ./static/css/src/input.css -o ./static/css/src/output.css --watch",
    "build": "npx @tailwindcss/cli -i ./static/css/src/input.css -o ./static/css/src/output.css --minify",
    "build:dev": "npx @tailwindcss/cli -i ./static/css/src/input.css -o ./static/css/src/output.css",
    "pretty": "prettier --write ."
  },
  "keywords": [],
  "author": "difegam",
  "license": "ISC",
  "devDependencies": {
    "daisyui": "^5.5.14",
    "tailwindcss": "^4.0.0",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  }
}

{
  "name": "django-tailwindcss-starter",
  "version": "1.0.0",
  "description": "A starter template for integrating Tailwind CSS with Django projects.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/difegam/django-starter-template"
  },
  "keywords": [
    "django",
    "tailwind",
    "daisyui",
    "htmx",
    "alpine"
  ],
  "author": "difegam",
  "license": "ISC",
  "scripts": {
    "css:dev": "tailwindcss -i ./src/static/css/input.css -o ./src/static/css/output.css --watch",
    "css:build": "tailwindcss -i ./src/static/css/input.css -o ./src/static/css/output.css --minify",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "daisyui": "^5.5.14",
    "tailwindcss": "^4.0.0",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14"
  },
  "dependencies": {
    "alpinejs": "^3.14.0",
    "htmx.org": "^2.0.0"
  },
  "lint-staged": {
    "*.{js,jsx}": "eslint --fix",
    "*.{js,jsx,json,css,md,mdx,html}": "prettier --write"
  }
}

# =============================================================================
# Django Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit the real .env file — it is listed in .gitignore.
#
# Required variables have no default and must be set explicitly.
# Optional variables are commented out; the default value is shown.
# =============================================================================


# -----------------------------------------------------------------------------
# SECRET_KEY  (required)
# -----------------------------------------------------------------------------
# A long, random string used by Django for cryptographic signing (sessions,
# CSRF tokens, password resets, etc.).  Must be unique per environment and
# kept strictly private.
#
# Generate a new key:  openssl rand -base64 48
# -----------------------------------------------------------------------------
SECRET_KEY='replace-with-a-securely-generated-secret-key'


# -----------------------------------------------------------------------------
# DEBUG  (default: False)
# -----------------------------------------------------------------------------
# Controls Django's debug mode.
#   True  — detailed error pages, auto-reload, no email sending.  Dev only.
#   False — production-safe behaviour; requires ALLOWED_HOSTS to be set.
#
# Never set DEBUG=True in a publicly accessible environment.
# -----------------------------------------------------------------------------
DEBUG=False


# -----------------------------------------------------------------------------
# ALLOWED_HOSTS  (default: localhost,127.0.0.1)
# -----------------------------------------------------------------------------
# Comma-separated list of hostnames/IP addresses that this Django site can
# serve.  Prevents HTTP Host-header attacks.
#
# Examples:
#   Development : ALLOWED_HOSTS=localhost,127.0.0.1
#   Production  : ALLOWED_HOSTS=example.com,www.example.com
# -----------------------------------------------------------------------------
# ALLOWED_HOSTS=localhost,127.0.0.1


# -----------------------------------------------------------------------------
# DATABASE_URL  (default: sqlite:///src/db.sqlite3)
# -----------------------------------------------------------------------------
# Connection string parsed by django-environ into Django's DATABASES setting.
#
# Supported schemes and examples:
#   SQLite (dev)   : sqlite:///db.sqlite3
#   PostgreSQL     : postgres://USER:PASSWORD@HOST:5432/DBNAME
#   MySQL/MariaDB  : mysql://USER:PASSWORD@HOST:3306/DBNAME
#
# Leave commented out to use the default SQLite file during development.
# -----------------------------------------------------------------------------
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/DBNAME


# -----------------------------------------------------------------------------
# TIME_ZONE  (default: UTC)
# -----------------------------------------------------------------------------
# The default time zone used for datetime storage and display.
# Must be a valid IANA tz identifier: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
#
# Examples: UTC, America/New_York, Europe/London, Asia/Tokyo
# -----------------------------------------------------------------------------
# TIME_ZONE=UTC


# -----------------------------------------------------------------------------
# EMAIL_BACKEND  (default: django.core.mail.backends.smtp.EmailBackend)
# -----------------------------------------------------------------------------
# Controls how Django sends outgoing email.
#
# Common options:
#   Development (prints to console, no real email sent):
#     EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
#   Development (writes emails to files):
#     EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend
#
#   Production (sends via SMTP — also configure EMAIL_HOST, EMAIL_PORT, etc.):
#     EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# -----------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# =============================================================================
# Django Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit the real .env file — it is listed in .gitignore.
#
# Required variables have no default and must be set explicitly.
# Optional variables are commented out; the default value is shown.
#
# Follows the Twelve-Factor App principle: all configuration via environment.
# =============================================================================


# =============================================================================
# 1. Core
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO_SETTINGS_MODULE  (default: config.settings)
# -----------------------------------------------------------------------------
# Path to the settings module Django loads.
# For local development keep the default; for production, set this if you
# have a separate production settings file.
# -----------------------------------------------------------------------------
# DJANGO_SETTINGS_MODULE=config.settings

# -----------------------------------------------------------------------------
# SECRET_KEY  (required)
# -----------------------------------------------------------------------------
# A long, random string used by Django for cryptographic signing (sessions,
# CSRF tokens, password resets, etc.).  Must be unique per environment.
#
# Generate a new key:
#   just django secret
#   openssl rand -base64 48
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# -----------------------------------------------------------------------------
SECRET_KEY='replace-with-a-securely-generated-secret-key'

# -----------------------------------------------------------------------------
# DEBUG  (default: True)
# -----------------------------------------------------------------------------
# Controls Django's debug mode.
#   True  — detailed error pages, auto-reload, no email sending.  Dev only.
#   False — production-safe behaviour; requires ALLOWED_HOSTS to be set.
#
# NEVER set DEBUG=True in a publicly accessible environment.
# -----------------------------------------------------------------------------
DEBUG=True

# -----------------------------------------------------------------------------
# ALLOWED_HOSTS  (default: localhost,127.0.0.1)
# -----------------------------------------------------------------------------
# Comma-separated list of hostnames/IP addresses that this Django site can
# serve.  Prevents HTTP Host-header attacks.
#
# Examples:
#   Development : ALLOWED_HOSTS=localhost,127.0.0.1
#   Production  : ALLOWED_HOSTS=example.com,www.example.com
# -----------------------------------------------------------------------------
# ALLOWED_HOSTS=localhost,127.0.0.1


# =============================================================================
# 2. Security
# =============================================================================

# -----------------------------------------------------------------------------
# CSRF_TRUSTED_ORIGINS  (required for any non-GET requests in production)
# -----------------------------------------------------------------------------
# Comma-separated list of trusted origins for unsafe requests (POST, PUT, DELETE).
# Must match the scheme and host of incoming requests exactly.
#
# When using Cloudflare, a CDN, or a reverse proxy, add the proxy's origin here.
#
# Examples:
#   Development : (not needed)
#   Production  : CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
#   Cloudflare  : CSRF_TRUSTED_ORIGINS=https://example.com
# -----------------------------------------------------------------------------
# CSRF_TRUSTED_ORIGINS=https://example.com

# -----------------------------------------------------------------------------
# SECURE_SSL_REDIRECT  (default: False)
# -----------------------------------------------------------------------------
# When True, Django redirects all HTTP requests to HTTPS.  Set this behind
# a TLS-terminating proxy (Cloudflare, Caddy, Nginx, etc.) or on PaaS
# platforms that handle TLS for you.
# -----------------------------------------------------------------------------
# SECURE_SSL_REDIRECT=False

# -----------------------------------------------------------------------------
# SECURE_HSTS_SECONDS  (default: 0)
# -----------------------------------------------------------------------------
# Number of seconds browsers should remember that this site is HTTPS-only.
# Enable only after confirming HTTPS works end-to-end.
# -----------------------------------------------------------------------------
# SECURE_HSTS_SECONDS=31536000

# -----------------------------------------------------------------------------
# SECURE_HSTS_INCLUDE_SUBDOMAINS  (default: False)
# -----------------------------------------------------------------------------
# Include all subdomains in the HSTS policy. Enable only when every subdomain
# supports HTTPS.
# -----------------------------------------------------------------------------
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# -----------------------------------------------------------------------------
# SECURE_HSTS_PRELOAD  (default: False)
# -----------------------------------------------------------------------------
# Opt in to browser preload lists. Enable only if you understand the permanent
# operational impact and meet preload requirements.
# -----------------------------------------------------------------------------
# SECURE_HSTS_PRELOAD=True

# -----------------------------------------------------------------------------
# SESSION_COOKIE_SECURE / CSRF_COOKIE_SECURE  (default: False)
# -----------------------------------------------------------------------------
# When True, session and CSRF cookies are sent only over HTTPS.
# Set both to True in production behind TLS.
# -----------------------------------------------------------------------------
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# -----------------------------------------------------------------------------
# SECURE_CONTENT_TYPE_NOSNIFF  (default: True)
# -----------------------------------------------------------------------------
# Adds X-Content-Type-Options: nosniff through Django's SecurityMiddleware.
# -----------------------------------------------------------------------------
# SECURE_CONTENT_TYPE_NOSNIFF=True


# =============================================================================
# 3. Database
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE_URL  (default: sqlite:///src/db.sqlite3)
# -----------------------------------------------------------------------------
# Connection string parsed by django-environ into Django's DATABASES setting.
#
# Supported schemes and examples:
#   SQLite (dev)   : sqlite:///db.sqlite3
#   PostgreSQL     : postgres://USER:PASSWORD@HOST:5432/DBNAME
#   MySQL/MariaDB  : mysql://USER:PASSWORD@HOST:3306/DBNAME
#
# Leave commented out to use the default SQLite file during development.
# -----------------------------------------------------------------------------
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/DBNAME

# -----------------------------------------------------------------------------
# PostgreSQL container settings (used by Docker Compose)
# -----------------------------------------------------------------------------
# These variables configure the PostgreSQL container in Docker Compose. Django
# does not read them directly; set DATABASE_URL to point Django at PostgreSQL.
#
# POSTGRES_HOST is the service name when using Docker Compose (e.g. "db").
# -----------------------------------------------------------------------------
# DATABASE_URL=postgres://postgres:postgres@db:5432/django_db
# POSTGRES_DB=mydb
# POSTGRES_USER=myuser
# POSTGRES_PASSWORD=supersecret
# POSTGRES_HOST=db
# POSTGRES_PORT=5432


# =============================================================================
# 4. Email
# =============================================================================

# -----------------------------------------------------------------------------
# EMAIL_URL  (default: console://)
# -----------------------------------------------------------------------------
# Full email connection string parsed by django-environ (env.email_url()).
# In production, set this to your SMTP server.
#
# Supported schemes:
#   SMTP+SSL   : smtp+ssl://USER:PASSWORD@HOST:465
#   SMTP+STARTTLS : smtp+tls://USER:PASSWORD@HOST:587
#   Console    : console://  (prints to stdout — dev only)
#
# Examples:
#   EMAIL_URL=smtp+tls://user:pass@smtp.example.com:587
#   EMAIL_URL=smtp+ssl://user:pass@smtp.example.com:465
# -----------------------------------------------------------------------------
# EMAIL_URL=console://


# =============================================================================
# 5. Internationalization
# =============================================================================

# -----------------------------------------------------------------------------
# TIME_ZONE  (default: UTC)
# -----------------------------------------------------------------------------
# The default time zone used for datetime storage and display.
# Must be a valid IANA tz identifier: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
#
# Examples: UTC, America/New_York, Europe/London, Europe/Lisbon, Asia/Tokyo
# -----------------------------------------------------------------------------
# TIME_ZONE=UTC

# -----------------------------------------------------------------------------
# LANGUAGE_CODE  (default: en-us)
# -----------------------------------------------------------------------------
# The default language for this installation.  Must be a valid Django language
# code (ISO 639-1 with optional locale variant).
#
# Examples: en-us, en-gb, pt, pt-br, fr, de
# -----------------------------------------------------------------------------
# LANGUAGE_CODE=en-us


# =============================================================================
# 6. Auth URLs
# =============================================================================

# -----------------------------------------------------------------------------
# LOGIN_URL  (default: /accounts/login/)
# -----------------------------------------------------------------------------
# Path to the login view where unauthenticated users are redirected.
# Django's @login_required decorator redirects here.
# -----------------------------------------------------------------------------
# LOGIN_URL=/accounts/login/

# -----------------------------------------------------------------------------
# LOGIN_REDIRECT_URL  (default: home)
# -----------------------------------------------------------------------------
# URL where users are redirected after successful login.
# Accepts a URL path or a named URL pattern.
# -----------------------------------------------------------------------------
# LOGIN_REDIRECT_URL=home


# =============================================================================
# 7. Superuser (optional)
# -----------------------------------------------------------------------------
# When set, the Docker entrypoint will create a superuser automatically.
# If omitted, no superuser is created.  Use DJANGO_SUPERUSER_PASSWORD
# for local development only; for production, prefer DJANGO_SUPERUSER_PASSWORD_FILE
# which reads the password from a file (Docker secrets / /run/secrets).
# =============================================================================

# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com

# Production (preferred): read password from a file
# DJANGO_SUPERUSER_PASSWORD_FILE=/run/secrets/su_password

# Development only: password inline (NEVER commit real .env)
# DJANGO_SUPERUSER_PASSWORD=changeme


# =============================================================================
# 8. Platform
# =============================================================================

# -----------------------------------------------------------------------------
# PORT  (default: 8000)
# -----------------------------------------------------------------------------
# The port Gunicorn binds to.  Most PaaS providers (Railway, Fly.io, Dokploy)
# inject this automatically via the runtime environment.
# -----------------------------------------------------------------------------
# PORT=8000


# =============================================================================
# 9. Cloudflare
# =============================================================================

# -----------------------------------------------------------------------------
# CLOUDFLARE_API_TOKEN  (required for production Caddy reverse proxy)
# -----------------------------------------------------------------------------
# Create a Cloudflare API token at https://dash.cloudflare.com/profile/api-tokens
# with Zone -> Zone -> Read and Zone -> DNS -> Edit permissions.
# Restrict it to the specific zone(s) you need.
# -----------------------------------------------------------------------------
# CLOUDFLARE_API_TOKEN=
